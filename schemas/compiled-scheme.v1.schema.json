{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/compiled-scheme.v1.schema.json",
  "title": "scheme-tokens compiled color scheme v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "modes", "defaultMode", "tokens"],
  "properties": {
    "kind": {
      "const": "scheme-tokens/compiled-color-scheme"
    },
    "formatVersion": {
      "const": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "token-graph.v1.schema.json#/$defs/segment"
      }
    },
    "defaultMode": {
      "$ref": "token-graph.v1.schema.json#/$defs/segment"
    },
    "tokens": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["visibility", "valueByMode", "origin", "dependenciesByMode"],
        "properties": {
          "visibility": {
            "$ref": "token-graph.v1.schema.json#/$defs/visibility"
          },
          "valueByMode": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "$ref": "token-graph.v1.schema.json#/$defs/segment"
            },
            "additionalProperties": {
              "$ref": "token-graph.v1.schema.json#/$defs/colorValue"
            }
          },
          "origin": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind"],
                "properties": {
                  "kind": {
                    "const": "graph"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "id"],
                "properties": {
                  "kind": {
                    "const": "layer"
                  },
                  "id": {
                    "$ref": "token-graph.v1.schema.json#/$defs/segment"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "id"],
                "properties": {
                  "kind": {
                    "const": "source"
                  },
                  "id": {
                    "$ref": "token-graph.v1.schema.json#/$defs/segment"
                  },
                  "sourceToken": {
                    "type": "string"
                  }
                }
              }
            ]
          },
          "dependenciesByMode": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "$ref": "token-graph.v1.schema.json#/$defs/segment"
            },
            "additionalProperties": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
              }
            }
          },
          "description": {
            "type": "string"
          },
          "deprecated": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "extensions": {
            "$ref": "token-graph.v1.schema.json#/$defs/extensions"
          }
        }
      }
    }
  }
}
