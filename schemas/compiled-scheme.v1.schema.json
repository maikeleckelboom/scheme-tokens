{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/compiled-scheme.v1.schema.json",
  "title": "scheme-tokens compiled scheme v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["formatVersion", "modes", "defaultMode", "tokens"],
  "properties": {
    "formatVersion": {
      "const": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "token-graph.v1.schema.json#/$defs/segment"
      }
    },
    "defaultMode": {
      "$ref": "token-graph.v1.schema.json#/$defs/segment"
    },
    "tokens": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["visibility", "valueByMode", "origin", "dependenciesByMode"],
        "properties": {
          "visibility": {
            "enum": ["public", "internal"]
          },
          "valueByMode": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "$ref": "token-graph.v1.schema.json#/$defs/segment"
            },
            "additionalProperties": {
              "$ref": "#/$defs/resolvedColor"
            }
          },
          "origin": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind"],
                "properties": {
                  "kind": {
                    "const": "graph"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "id"],
                "properties": {
                  "kind": {
                    "const": "layer"
                  },
                  "id": {
                    "$ref": "token-graph.v1.schema.json#/$defs/segment"
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["kind", "id"],
                "properties": {
                  "kind": {
                    "const": "source"
                  },
                  "id": {
                    "$ref": "token-graph.v1.schema.json#/$defs/segment"
                  },
                  "sourceToken": {
                    "type": "string"
                  }
                }
              }
            ]
          },
          "dependenciesByMode": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": {
              "$ref": "token-graph.v1.schema.json#/$defs/segment"
            },
            "additionalProperties": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
              }
            }
          },
          "description": {
            "type": "string"
          },
          "deprecated": {
            "anyOf": [
              {
                "type": "boolean"
              },
              {
                "type": "string",
                "minLength": 1
              }
            ]
          },
          "extensions": {
            "$ref": "token-graph.v1.schema.json#/$defs/extensions"
          }
        }
      }
    }
  },
  "$defs": {
    "resolvedColor": {
      "oneOf": [
        {
          "$ref": "#/$defs/resolvedSrgbColor"
        },
        {
          "$ref": "#/$defs/resolvedDisplayP3Color"
        },
        {
          "$ref": "#/$defs/resolvedOklchColor"
        }
      ]
    },
    "resolvedSrgbColor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colorSpace", "r", "g", "b", "alpha"],
      "properties": {
        "colorSpace": {
          "const": "srgb"
        },
        "r": {
          "type": "number"
        },
        "g": {
          "type": "number"
        },
        "b": {
          "type": "number"
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "resolvedDisplayP3Color": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colorSpace", "r", "g", "b", "alpha"],
      "properties": {
        "colorSpace": {
          "const": "display-p3"
        },
        "r": {
          "type": "number"
        },
        "g": {
          "type": "number"
        },
        "b": {
          "type": "number"
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "resolvedOklchColor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colorSpace", "l", "c", "h", "alpha"],
      "properties": {
        "colorSpace": {
          "const": "oklch"
        },
        "l": {
          "type": "number"
        },
        "c": {
          "type": "number",
          "minimum": 0
        },
        "h": {
          "type": "number"
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
