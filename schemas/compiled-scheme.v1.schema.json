{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/compiled-scheme.v1.schema.json",
  "title": "scheme-tokens compiled scheme v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "modes", "defaultMode", "tokens", "metadataByToken"],
  "properties": {
    "kind": {
      "const": "scheme-tokens/compiled-scheme"
    },
    "formatVersion": {
      "const": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "token-graph.v1.schema.json#/$defs/segment"
      }
    },
    "defaultMode": {
      "$ref": "token-graph.v1.schema.json#/$defs/segment"
    },
    "tokens": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/compiledToken"
      }
    },
    "metadataByToken": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/compiledTokenMetadata"
      }
    }
  },
  "$defs": {
    "compiledToken": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "token-graph.v1.schema.json#/$defs/segment"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "compiledTokenMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["visibility", "origin", "dependenciesByMode"],
      "properties": {
        "visibility": {
          "$ref": "token-graph.v1.schema.json#/$defs/visibility"
        },
        "origin": {
          "oneOf": [
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind"],
              "properties": {
                "kind": {
                  "const": "graph"
                }
              }
            },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["kind", "id"],
              "properties": {
                "kind": {
                  "const": "layer"
                },
                "id": {
                  "$ref": "token-graph.v1.schema.json#/$defs/segment"
                }
              }
            }
          ]
        },
        "dependenciesByMode": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "token-graph.v1.schema.json#/$defs/segment"
          },
          "additionalProperties": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "$ref": "token-graph.v1.schema.json#/$defs/tokenKey"
            }
          }
        },
        "description": {
          "type": "string"
        },
        "deprecated": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "extensions": {
          "$ref": "token-graph.v1.schema.json#/$defs/extensions"
        }
      }
    }
  }
}
