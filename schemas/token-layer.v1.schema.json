{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/token-layer.v1.schema.json",
  "title": "scheme-tokens token layer v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "id", "defaultVisibility", "tokens"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "scheme-tokens/token-layer"
    },
    "formatVersion": {
      "const": 1
    },
    "id": {
      "$ref": "token-graph.v1.schema.json#/$defs/segment"
    },
    "defaultVisibility": {
      "$ref": "token-graph.v1.schema.json#/$defs/visibility"
    },
    "tokens": {
      "$ref": "token-graph.v1.schema.json#/$defs/tokenRecord"
    }
  }
}
