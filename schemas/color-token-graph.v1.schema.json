{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/color-token-graph.v1.schema.json",
  "title": "scheme-tokens color token graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "modes", "defaultMode", "defaultVisibility", "tokens"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "scheme-tokens/color-token-graph"
    },
    "formatVersion": {
      "const": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/segment"
      }
    },
    "defaultMode": {
      "$ref": "#/$defs/segment"
    },
    "defaultVisibility": {
      "$ref": "#/$defs/visibility"
    },
    "tokens": {
      "$ref": "#/$defs/tokenRecord"
    },
    "layers": {
      "type": "array",
      "items": {
        "$ref": "color-token-layer.v1.schema.json"
      }
    }
  },
  "$defs": {
    "segment": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "tokenKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)*$"
    },
    "visibility": {
      "enum": ["public", "internal"]
    },
    "tokenRecord": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/tokenKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/tokenDefinition"
      }
    },
    "tokenDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "description": {
          "type": "string"
        },
        "deprecated": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        },
        "value": {
          "$ref": "#/$defs/expression"
        },
        "valueByMode": {
          "$ref": "#/$defs/expressionByModeRecord"
        }
      },
      "oneOf": [
        {
          "required": ["value"],
          "not": {
            "required": ["valueByMode"]
          }
        },
        {
          "required": ["valueByMode"],
          "not": {
            "required": ["value"]
          }
        }
      ]
    },
    "expressionByModeRecord": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/segment"
      },
      "additionalProperties": {
        "$ref": "#/$defs/expression"
      }
    },
    "expression": {
      "anyOf": [
        {
          "$ref": "#/$defs/colorValue"
        },
        {
          "$ref": "#/$defs/reference"
        }
      ]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/tokenKey"
        }
      }
    },
    "colorSpace": {
      "enum": [
        "srgb",
        "srgb-linear",
        "hsl",
        "hwb",
        "lab",
        "lch",
        "oklab",
        "oklch",
        "display-p3",
        "a98-rgb",
        "prophoto-rgb",
        "rec2020",
        "xyz-d65",
        "xyz-d50"
      ]
    },
    "colorComponent": {
      "anyOf": [
        {
          "type": "number"
        },
        {
          "const": "none"
        }
      ]
    },
    "unitComponent": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        {
          "const": "none"
        }
      ]
    },
    "percentComponent": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        {
          "const": "none"
        }
      ]
    },
    "nonNegativeComponent": {
      "anyOf": [
        {
          "type": "number",
          "minimum": 0
        },
        {
          "const": "none"
        }
      ]
    },
    "unitComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/unitComponent"
        },
        {
          "$ref": "#/$defs/unitComponent"
        },
        {
          "$ref": "#/$defs/unitComponent"
        }
      ]
    },
    "hslHwbComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/colorComponent"
        },
        {
          "$ref": "#/$defs/percentComponent"
        },
        {
          "$ref": "#/$defs/percentComponent"
        }
      ]
    },
    "labComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/percentComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        }
      ]
    },
    "lchComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/percentComponent"
        },
        {
          "$ref": "#/$defs/nonNegativeComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        }
      ]
    },
    "oklabComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/unitComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        }
      ]
    },
    "oklchComponents": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/unitComponent"
        },
        {
          "$ref": "#/$defs/nonNegativeComponent"
        },
        {
          "$ref": "#/$defs/colorComponent"
        }
      ]
    },
    "colorValue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["colorSpace", "components", "alpha"],
      "properties": {
        "colorSpace": {
          "$ref": "#/$defs/colorSpace"
        },
        "components": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "$ref": "#/$defs/colorComponent"
          }
        },
        "alpha": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "hex": {
          "type": "string",
          "pattern": "^#[0-9a-fA-F]{6}(?:[0-9a-fA-F]{2})?$"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "colorSpace": {
                  "enum": [
                    "srgb",
                    "srgb-linear",
                    "display-p3",
                    "a98-rgb",
                    "prophoto-rgb",
                    "rec2020",
                    "xyz-d65",
                    "xyz-d50"
                  ]
                },
                "components": {
                  "$ref": "#/$defs/unitComponents"
                }
              }
            },
            {
              "properties": {
                "colorSpace": {
                  "enum": ["hsl", "hwb"]
                },
                "components": {
                  "$ref": "#/$defs/hslHwbComponents"
                }
              }
            },
            {
              "properties": {
                "colorSpace": {
                  "const": "lab"
                },
                "components": {
                  "$ref": "#/$defs/labComponents"
                }
              }
            },
            {
              "properties": {
                "colorSpace": {
                  "const": "lch"
                },
                "components": {
                  "$ref": "#/$defs/lchComponents"
                }
              }
            },
            {
              "properties": {
                "colorSpace": {
                  "const": "oklab"
                },
                "components": {
                  "$ref": "#/$defs/oklabComponents"
                }
              }
            },
            {
              "properties": {
                "colorSpace": {
                  "const": "oklch"
                },
                "components": {
                  "$ref": "#/$defs/oklchComponents"
                }
              }
            }
          ]
        }
      ]
    },
    "extensions": {
      "type": "object"
    }
  }
}
