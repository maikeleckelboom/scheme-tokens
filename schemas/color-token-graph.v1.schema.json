{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scheme-tokens.dev/schemas/color-token-graph.v1.schema.json",
  "title": "scheme-tokens color token graph v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "formatVersion", "modes", "defaultMode", "defaultVisibility", "tokens"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "kind": {
      "const": "scheme-tokens/color-token-graph"
    },
    "formatVersion": {
      "const": 1
    },
    "modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/segment"
      }
    },
    "defaultMode": {
      "$ref": "#/$defs/segment"
    },
    "defaultVisibility": {
      "$ref": "#/$defs/visibility"
    },
    "tokens": {
      "$ref": "#/$defs/tokenRecord"
    },
    "layers": {
      "type": "array",
      "items": {
        "$ref": "color-token-layer.v1.schema.json"
      }
    }
  },
  "$defs": {
    "segment": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$"
    },
    "tokenKey": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.[a-z][a-z0-9]*(?:-[a-z0-9]+)*)*$"
    },
    "visibility": {
      "enum": ["public", "internal"]
    },
    "tokenRecord": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/tokenKey"
      },
      "additionalProperties": {
        "$ref": "#/$defs/tokenDefinition"
      }
    },
    "tokenDefinition": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "description": {
          "type": "string"
        },
        "deprecated": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "string",
              "minLength": 1
            }
          ]
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        },
        "value": {
          "$ref": "#/$defs/expression"
        },
        "valueByMode": {
          "$ref": "#/$defs/expressionByModeRecord"
        }
      },
      "oneOf": [
        {
          "required": ["value"],
          "not": {
            "required": ["valueByMode"]
          }
        },
        {
          "required": ["valueByMode"],
          "not": {
            "required": ["value"]
          }
        }
      ]
    },
    "expressionByModeRecord": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "$ref": "#/$defs/segment"
      },
      "additionalProperties": {
        "$ref": "#/$defs/expression"
      }
    },
    "expression": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "$ref": "#/$defs/reference"
        }
      ]
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref"],
      "properties": {
        "ref": {
          "$ref": "#/$defs/tokenKey"
        }
      }
    },
    "extensions": {
      "type": "object"
    }
  }
}
