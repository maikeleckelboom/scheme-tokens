{
  "name": "@color-scheme-tokens/source-material3",
  "version": "0.0.0",
  "private": true,
  "description": "Material 3 source adapter for color-scheme-tokens.",
  "keywords": [
    "color-scheme",
    "design-tokens",
    "material-3",
    "token-graph"
  ],
  "license": "MIT",
  "author": "Maikel Eckelboom",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.lib.json && tsc -p tsconfig.test.json && tsc -p tsconfig.scripts.json",
    "lint": "oxlint . --import-plugin --vitest-plugin --deny-warnings",
    "test": "vitest run",
    "package:check": "pnpm build && publint --strict && attw --pack . --profile esm-only",
    "check:tarball": "node --experimental-strip-types scripts/check-tarball.ts",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm format",
    "release:check": "pnpm validate && pnpm package:check && pnpm check:tarball",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "@material/material-color-utilities": "0.4.0"
  },
  "devDependencies": {
    "color-scheme-tokens": "workspace:*"
  },
  "peerDependencies": {
    "color-scheme-tokens": "0.0.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.7.0"
}
