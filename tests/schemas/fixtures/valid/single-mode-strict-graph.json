{
  "$schema": "https://scheme-tokens.dev/schemas/token-graph.v1.schema.json",
  "kind": "scheme-tokens/color-token-graph",
  "formatVersion": 1,
  "modes": ["base"],
  "defaultMode": "base",
  "defaultVisibility": "public",
  "tokens": {
    "brand.primary": {
      "description": "Primary brand color.",
      "value": {
        "colorSpace": "srgb",
        "components": [0.4, 0.31, 0.64],
        "alpha": 1
      }
    },
    "surface.canvas": {
      "value": {
        "colorSpace": "srgb",
        "components": [1, 1, 1],
        "alpha": 1
      }
    }
  }
}
