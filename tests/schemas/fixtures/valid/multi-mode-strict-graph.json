{
  "$schema": "https://scheme-tokens.dev/schemas/token-graph.v1.schema.json",
  "kind": "scheme-tokens/token-graph",
  "formatVersion": 1,
  "modes": ["light", "dark"],
  "defaultMode": "light",
  "defaultVisibility": "internal",
  "tokens": {
    "brand.primary": {
      "extensions": {
        "app.role": "source",
        "UPSTREAM vendor/key": {
          "safe": true
        }
      },
      "valueByMode": {
        "light": "#6750a4",
        "dark": "#d0bcff"
      }
    },
    "brand.on-primary": {
      "valueByMode": {
        "light": "#ffffff",
        "dark": "#381e72"
      }
    },
    "button.background": {
      "visibility": "public",
      "value": {
        "ref": "brand.primary"
      }
    },
    "button.foreground": {
      "visibility": "public",
      "value": {
        "ref": "brand.on-primary"
      }
    }
  }
}
