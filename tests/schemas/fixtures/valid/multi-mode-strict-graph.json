{
  "$schema": "https://scheme-tokens.dev/schemas/token-graph.v1.schema.json",
  "formatVersion": 1,
  "modes": ["light", "dark"],
  "defaultMode": "light",
  "defaultVisibility": "internal",
  "tokens": {
    "brand.primary": {
      "extensions": {
        "app.role": "source"
      },
      "valueByMode": {
        "light": {
          "colorSpace": "srgb",
          "r": 0.4,
          "g": 0.31,
          "b": 0.64,
          "alpha": 1
        },
        "dark": {
          "colorSpace": "srgb",
          "r": 0.82,
          "g": 0.74,
          "b": 1,
          "alpha": 1
        }
      }
    },
    "brand.on-primary": {
      "valueByMode": {
        "light": {
          "colorSpace": "srgb",
          "r": 1,
          "g": 1,
          "b": 1,
          "alpha": 1
        },
        "dark": {
          "colorSpace": "srgb",
          "r": 0.22,
          "g": 0.12,
          "b": 0.45,
          "alpha": 1
        }
      }
    },
    "button.background": {
      "visibility": "public",
      "value": {
        "ref": "brand.primary"
      }
    },
    "button.foreground": {
      "visibility": "public",
      "value": {
        "ref": "brand.on-primary"
      }
    }
  }
}
