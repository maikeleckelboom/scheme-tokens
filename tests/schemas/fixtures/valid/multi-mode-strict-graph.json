{
  "$schema": "https://scheme-tokens.dev/schemas/token-graph.v1.schema.json",
  "kind": "scheme-tokens/color-token-graph",
  "formatVersion": 1,
  "modes": ["light", "dark"],
  "defaultMode": "light",
  "defaultVisibility": "internal",
  "tokens": {
    "brand.primary": {
      "extensions": {
        "app.role": "source",
        "UPSTREAM vendor/key": {
          "safe": true
        }
      },
      "valueByMode": {
        "light": {
          "colorSpace": "srgb",
          "components": [0.4, 0.31, 0.64],
          "alpha": 1
        },
        "dark": {
          "colorSpace": "srgb",
          "components": [0.82, 0.74, 1],
          "alpha": 1
        }
      }
    },
    "brand.on-primary": {
      "valueByMode": {
        "light": {
          "colorSpace": "srgb",
          "components": [1, 1, 1],
          "alpha": 1
        },
        "dark": {
          "colorSpace": "srgb",
          "components": [0.22, 0.12, 0.45],
          "alpha": 1
        }
      }
    },
    "button.background": {
      "visibility": "public",
      "value": {
        "ref": "brand.primary"
      }
    },
    "button.foreground": {
      "visibility": "public",
      "value": {
        "ref": "brand.on-primary"
      }
    }
  }
}
