{
  "name": "color-scheme-tokens",
  "version": "0.0.0",
  "private": true,
  "description": "Stable color scheme tokens for TypeScript apps.",
  "keywords": [
    "color-scheme",
    "css-variables",
    "design-tokens",
    "token-graph",
    "typescript"
  ],
  "license": "MIT",
  "author": "Maikel Eckelboom",
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --import-plugin --vitest-plugin --deny-warnings",
    "test": "vitest run",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt --write .",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm format",
    "check": "pnpm validate",
    "release:check": "pnpm validate && pnpm pack --dry-run",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.7.0"
}
